# ===== Supadata =====
# Получить ключ: https://supadata.ai  →  Dashboard → API Keys (есть бесплатный тариф)
SUPADATA_API_KEY=your_supadata_api_key_here

# ===== OpenRouter =====
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Модель LLM на OpenRouter (можно менять).
# Примеры: google/gemini-2.0-flash-001, openai/gpt-4o-mini, anthropic/claude-3.5-haiku
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Необязательно: для рейтинга приложения в OpenRouter
OPENROUTER_APP_URL=http://localhost:3000
OPENROUTER_APP_TITLE=YouTube Video Analyzer

# ===== Supabase (регистрация пользователей) =====
# Создать проект: https://supabase.com  →  Project Settings → API
# Обе переменные ПУБЛИЧНЫЕ (NEXT_PUBLIC_) — попадают в браузер. Это нормально:
# anon key защищён политиками Row Level Security, а не секретностью.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
